{
  "name": "Install Apache Web Server",
  "version": "1.0.0",
  "description": "Installs Apache httpd with mod_ssl and opens firewall ports 80 and 443.",
  "builtin": true,
  "image_patterns": {
    "ubuntu": "install_apache_deb.sh",
    "debian": "install_apache_deb.sh",
    "rocky": "install_apache_rpm.sh",
    "centos": "install_apache_rpm.sh",
    "*": "install_apache_deb.sh"
  },
  "steps": [
    {
      "type": "upload_scripts"
    },
    {
      "type": "execute",
      "command": "chmod +x ~/.fabric/recipes/install_apache/*.sh && sudo bash ~/.fabric/recipes/install_apache/{script}"
    }
  ],
  "post_actions": []
}
