{
  "name": "Install OVS Switch",
  "version": "1.0.0",
  "description": "Installs Open vSwitch, creates bridge br0, and sets up a systemd timer to auto-connect new dataplane interfaces every 15 seconds.",
  "builtin": true,
  "image_patterns": {
    "ubuntu": "install_ovs_switch_deb.sh",
    "debian": "install_ovs_switch_deb.sh",
    "rocky": "install_ovs_switch_rpm.sh",
    "centos": "install_ovs_switch_rpm.sh",
    "*": "install_ovs_switch_deb.sh"
  },
  "steps": [
    {
      "type": "upload_scripts"
    },
    {
      "type": "execute",
      "command": "chmod +x ~/.fabric/recipes/install_ovs_switch/*.sh && sudo bash ~/.fabric/recipes/install_ovs_switch/{script}"
    }
  ],
  "post_actions": []
}
