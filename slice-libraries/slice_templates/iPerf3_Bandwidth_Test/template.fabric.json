{
  "format": "fabric-slice-v1",
  "name": "iPerf3 Bandwidth Test",
  "nodes": [
    {
      "name": "iperf-server",
      "site": "@perf-a",
      "cores": 4,
      "ram": 8,
      "disk": 10,
      "vm_template": "iPerf3 Test Node",
      "boot_config": {
        "uploads": [],
        "commands": [
          {
            "id": "run-server",
            "command": "sudo docker run -d --name iperf3-server --restart always --net host networkstatic/iperf3 -s",
            "order": 10
          }
        ],
        "network": []
      },
      "components": [
        {
          "name": "FABNET",
          "model": "NIC_Basic"
        }
      ]
    },
    {
      "name": "iperf-client",
      "site": "@perf-b",
      "cores": 4,
      "ram": 8,
      "disk": 10,
      "vm_template": "iPerf3 Test Node",
      "components": [
        {
          "name": "FABNET",
          "model": "NIC_Basic"
        }
      ]
    }
  ],
  "networks": [
    {
      "name": "net-server",
      "type": "FABNetv4",
      "interfaces": [
        "iperf-server-FABNET-p1"
      ]
    },
    {
      "name": "net-client",
      "type": "FABNetv4",
      "interfaces": [
        "iperf-client-FABNET-p1"
      ]
    }
  ]
}