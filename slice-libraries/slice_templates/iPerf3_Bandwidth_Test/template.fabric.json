{
  "format": "fabric-slice-v1",
  "name": "iPerf3 Bandwidth Test",
  "nodes": [
    {
      "name": "iperf-server",
      "site": "@perf-a",
      "cores": 4,
      "ram": 8,
      "disk": 10,
      "image": "default_ubuntu_22",
      "boot_config": {
        "uploads": [],
        "commands": [
          {
            "id": "1",
            "command": "sudo apt-get update && sudo apt-get install -y iperf3",
            "order": 0
          },
          {
            "id": "2",
            "command": "nohup iperf3 -s -D",
            "order": 1
          }
        ],
        "network": []
      },
      "components": [
        {
          "name": "FABNET",
          "model": "NIC_Basic"
        }
      ]
    },
    {
      "name": "iperf-client",
      "site": "@perf-b",
      "cores": 4,
      "ram": 8,
      "disk": 10,
      "image": "default_ubuntu_22",
      "boot_config": {
        "uploads": [],
        "commands": [
          {
            "id": "1",
            "command": "sudo apt-get update && sudo apt-get install -y iperf3",
            "order": 0
          }
        ],
        "network": []
      },
      "components": [
        {
          "name": "FABNET",
          "model": "NIC_Basic"
        }
      ]
    }
  ],
  "networks": [
    {
      "name": "net-server",
      "type": "FABNetv4",
      "interfaces": [
        "iperf-server-FABNET-p1"
      ]
    },
    {
      "name": "net-client",
      "type": "FABNetv4",
      "interfaces": [
        "iperf-client-FABNET-p1"
      ]
    }
  ]
}
